{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/login", "dest": "/api/login.php" },
    { "src": "/register", "dest": "/api/register.php" },
    { "src": "/cek_login", "dest": "/api/cek_login.php" },
    { "src": "/dashboard_pasien", "dest": "/api/dashboard_pasien.php" },
    { "src": "/dashboard_petugas", "dest": "/api/dashboard_petugas.php" },
    
    { "src": "/get_(.*)", "dest": "/api/get_$1.php" },
    
    { "src": "/(.*)", "dest": "/$1" }
  ]
}