{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/login",
      "dest": "/api/login.php"
    },
    {
      "src": "/register",
      "dest": "/api/register.php"
    },
    {
      "src": "/dashboard_pasien",
      "dest": "/api/dashboard_pasien.php"
    },
    {
      "src": "/dashboard_petugas",
      "dest": "/api/dashboard_petugas.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}