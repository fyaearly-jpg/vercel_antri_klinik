{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/login", "dest": "/login.php" },
    { "src": "/register", "dest": "/register.php" },
    { "src": "/cek_login", "dest": "/api/cek_login.php" },
    { "src": "/dashboard_admin", "dest": "/api/dashboard_admin.php" },
    { "src": "/dashboard_petugas", "dest": "/api/dashboard_petugas.php" },
    { "src": "/monitoring", "dest": "/api/monitoring.php" },
    { "src": "/kelola_petugas", "dest": "/kelola_petugas.php" },
    { "src": "/kelola_pasien", "dest": "/kelola_pasien.php" },
    { "src": "/logout", "dest": "/api/logout.php" },
    
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}